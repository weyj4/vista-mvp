# Copy to .env and fill in. Loaded locally via `uv run --env-file .env`.
# In Cloud Run, set LANGSMITH_TRACING and LANGSMITH_PROJECT via --set-env-vars
# and LANGSMITH_API_KEY via --set-secrets (see README).

LANGSMITH_TRACING=true
LANGSMITH_PROJECT=quick-quotes-v0
LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com   # override for self-hosted

# Gemini (extract node). Without this, extract degrades to all-missing gracefully.
GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_TEMPERATURE=0.0
